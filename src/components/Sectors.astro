---

<section class="secteurs-section" id="secteurs">
  <div class="secteurs-overlay"></div> 
  <div class="container content-container"> 
    <div class="section-header">
      <h2 class="section-title">Secteurs D'Activités</h2>
    </div>

    <div class="secteurs-grid">
      {
        secteurs.map((secteur) => (
          <div class="secteur-card">
            <div class="icon-container" set:html={secteur.icon} />
            <h3 class="secteur-title">{secteur.title}</h3>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .secteurs-section {
    position: relative;
    padding: 6rem 0;
    background-image: url('/images/sectors.jpg');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
  }

  .secteurs-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .content-container {
    position: relative;
    z-index: 2;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-title {
    font-size: 2.5rem;
    color: #555555;
    margin-bottom: 0.5rem;
    font-weight: 700;
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.8);
    max-width: 600px;
    margin: 0 auto;
  }

  .secteurs-grid {
    display: grid;
    /* 5 cards per row natively */
    grid-template-columns: repeat(5, 1fr);
    gap: 1.5rem;
    justify-content: center;
  } 

  .secteur-card {
    width: 100%;
    height: 200px;
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 1.5rem;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.07);
    transition: all 0.3s ease;
    cursor: default;
  }

  .secteur-card:hover {
    transform: translateY(-5px);
    border-color: #009fe3;
    box-shadow: 0 10px 30px rgba(0, 159, 227, 0.15);
  }

  .icon-container {
    color: #009fe3;
    margin-bottom: 1rem;
    transition: color 0.3s ease;
  }

  .secteur-card:hover .icon-container {
    color: #007bb8;
  }

  .secteur-title {
    font-size: 1rem;
    font-weight: 600;
    color: #333333;
    line-height: 1.4;
  }

  /* Responsive breakpoints to keep nice sizing */
  @media (max-width: 1200px) {
    .secteurs-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 992px) {
    .secteurs-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .secteurs-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .secteurs-grid {
      grid-template-columns: repeat(1, 1fr);
    }
  }
</style>
