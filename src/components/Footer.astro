---
---
<footer class="footer">
  <div class="container footer-content">
    <div class="footer-brand">
      <a href="/" class="logo">Osaka<span class="text-gradient">Maroc</span></a>
      <p class="footer-desc">Delivering excellence with modern web experiences built for the future.</p>
    </div>
    
    <div class="footer-links">
      <div class="link-group">
        <h3>Company</h3>
        <ul>
          <li><a href="/about">About Us</a></li>
          <li><a href="/careers">Careers</a></li>
          <li><a href="/news">Newsroom</a></li>
        </ul>
      </div>
      <div class="link-group">
        <h3>Resources</h3>
        <ul>
          <li><a href="/help">Help Center</a></li>
          <li><a href="/guides">Guides</a></li>
          <li><a href="/api">API Status</a></li>
        </ul>
      </div>
      <div class="link-group">
        <h3>Legal</h3>
        <ul>
          <li><a href="/privacy">Privacy Policy</a></li>
          <li><a href="/terms">Terms of Service</a></li>
        </ul>
      </div>
    </div>
  </div>
  
  <div class="footer-bottom">
    <div class="container">
      <p>&copy; {new Date().getFullYear()} Osaka Maroc. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--bg-surface);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 4rem;
    margin-top: 4rem;
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 3rem;
    margin-bottom: 4rem;
  }

  .footer-brand {
    max-width: 300px;
  }

  .logo {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 800;
  }

  .footer-desc {
    margin-top: 1rem;
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  .footer-links {
    display: flex;
    gap: 4rem;
    flex-wrap: wrap;
  }

  .link-group h3 {
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
    color: var(--text-main);
  }

  .link-group ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .link-group a {
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  .link-group a:hover {
    color: var(--accent-primary);
  }

  .footer-bottom {
    padding: 2rem 0;
    text-align: center;
    color: var(--text-muted);
    font-size: 0.9rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  @media (max-width: 768px) {
    .footer-content {
      flex-direction: column;
    }
    .footer-links {
      gap: 2rem;
    }
  }
</style>
