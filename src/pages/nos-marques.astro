---

<Layout
  title="Nos Marques | Osaka Solutions Maroc"
  description="Découvrez toutes les marques de premier plan distribuées par Osaka Solutions Maroc. Plus de 15 ans d'expérience dans la distribution des fournitures et matériels industriels."
>
  <!-- Page Hero -->
  <section class="page-hero">
    <div class="hero-overlay"></div>
    <div class="container hero-content">
      <h1>Nos Marques</h1>
      <p class="breadcrumb"><a href="/">Accueil</a> <span>/</span> Nos Marques</p>
    </div>
  </section>

  <!-- Intro -->
  <section class="brands-intro">
    <div class="container">
      <div class="intro-inner">
        <p class="subtitle">
          Plus de 15 ans d'expérience dans la distribution des Fournitures et matérielles des Marques de premier plan pour l'industrie.
        </p>
      </div>
    </div>
  </section>

  <!-- All Brands Grid -->
  <section class="brands-grid-section">
    <div class="container">
      <ul class="brands-grid">
        {allBrands.map((src) => (
          <li class="brand-card">
            <img src={src} alt="Brand Logo" loading="lazy" />
          </li>
        ))}
      </ul>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .page-hero {
    position: relative;
    height: 280px;
    background: url('/images/AboutOsaka.webp') center/cover no-repeat;
    display: flex;
    align-items: center;
    margin-top: 80px;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(10, 10, 12, 0.65);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    color: #fff;
  }

  .hero-content h1 {
    font-size: 3rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
  }

  .breadcrumb {
    color: rgba(255,255,255,0.7);
    font-size: 0.95rem;
  }

  .breadcrumb a {
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb a:hover {
    color: #009FE3;
  }

  .breadcrumb span {
    margin: 0 0.5rem;
  }

  /* Intro */
  .brands-intro {
    padding: 3.5rem 0 2rem;
    background: #fff;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }

  .intro-inner {
    max-width: 780px;
    margin: 0 auto;
    text-align: center;
  }

  .subtitle {
    font-size: 1.15rem;
    color: #555;
    line-height: 1.8;
    border-left: 4px solid #009FE3;
    padding-left: 1.25rem;
    text-align: left;
  }

  /* Brands Grid */
  .brands-grid-section {
    padding: 4rem 0 6rem;
    background: #f9fafb;
  }

  .brands-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .brand-card {
    background: #fff;
    border: 1px solid rgba(0,0,0,0.07);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 110px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .brand-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,159,227,0.12);
    border-color: rgba(0,159,227,0.2);
  }

  .brand-card img {
    max-height: 70px;
    max-width: 140px;
    width: 100%;
    object-fit: contain;
    mix-blend-mode: multiply;
    filter: grayscale(20%);
    transition: filter 0.25s ease;
  }

  .brand-card:hover img {
    filter: grayscale(0%);
  }

  @media (max-width: 576px) {
    .brands-grid {
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    }
  }
</style>
